# ============================================================
# Meridian — .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Gemini API Keys (Google AI Studio — 3-account rotation) ---
GEMINI_API_KEY_A=           # Used by: PII Redactor + Router
GEMINI_API_KEY_B=           # Used by: Query Rewriter + Critic
GEMINI_API_KEY_C=           # Used by: Generator (gemini-2.5-pro)

# --- Gemini Embedding Key ---
GEMINI_EMBEDDING_KEY=       # Used by: Embedder (text/image/audio)
                             # Can share KEY_A or use a 4th key

# --- Milvus (Docker Standalone) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
