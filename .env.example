# ============================================================
# Meridian — .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Gemini API Key (Google AI Studio) ---
GEMINI_API_KEY_A=           # Used by: PII Redactor + Router (gemini-2.5-flash)

# --- DeepSeek API Key ---
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=           # Used by: Query Rewriter + Critic + Generator (deepseek-chat)

# --- Gemini Embedding Key ---
GEMINI_EMBEDDING_KEY=       # Used by: Embedder (text/image/audio)
                             # Can share GEMINI_API_KEY_A or use a separate key

# --- Milvus (Docker Standalone) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
