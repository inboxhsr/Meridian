# ============================================================
# Meridian — .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Gemini API Keys (Google AI Studio) ---
GEMINI_API_KEY_A=               # Intent classifier (gemini-2.5-flash) + image captioning in eval
GEMINI_EMBEDDING_KEY=           # Embedder (gemini-embedding-001, 3072-dim)

# --- DeepSeek API Key ---
DEEPSEEK_API_KEY=               # Query rewriter, critic, generator (deepseek-v4-flash)

# --- Milvus (Docker Standalone) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
